{
  "name": "manti-ui-workspace",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "build": "pnpm build:packages && pnpm build:storybook",
    "build:packages": "pnpm --filter @manti-ui/tokens build && pnpm --filter @manti-ui/styles build && pnpm --filter @manti-ui/folds build && pnpm --filter @manti-ui/react build",
    "build:storybook": "HOME=$PWD/.cache STORYBOOK_DISABLE_TELEMETRY=1 storybook build",
    "dev": "pnpm build:packages && pnpm storybook",
    "docs:dev": "pnpm build:packages && vite packages/docs",
    "docs:build": "pnpm build:packages && vite build packages/docs",
    "docs:preview": "vite preview packages/docs",
    "build:site": "pnpm docs:build && pnpm build:storybook && rm -rf packages/docs/dist/storybook && cp -r storybook-static packages/docs/dist/storybook",
    "gen:tokens": "pnpm --filter @manti-ui/styles gen:tokens",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build:packages && changeset publish",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "storybook": "HOME=$PWD/.cache STORYBOOK_DISABLE_TELEMETRY=1 storybook dev -p 6006",
    "typecheck": "pnpm -r --if-present typecheck && tsc -p tsconfig.storybook.json --noEmit",
    "verify": "pnpm lint && pnpm typecheck && pnpm build"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^10.0.0",
    "@manti-ui/styles": "workspace:*",
    "@storybook/addon-a11y": "^10.4.3",
    "@storybook/addon-docs": "^10.4.3",
    "@storybook/react-vite": "^10.4.3",
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^10.0.0",
    "globals": "^16.0.0",
    "prettier": "^3.8.4",
    "storybook": "^10.4.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.16"
  }
}
