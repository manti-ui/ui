{
  "name": "@manti-ui/styles",
  "version": "0.0.0",
  "description": "Framework-agnostic CSS for Manti UI.",
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./index.css": {
      "development": "./src/index.css",
      "default": "./dist/index.css"
    },
    "./tokens.css": {
      "development": "./src/tokens.css",
      "default": "./dist/tokens.css"
    },
    "./tailwind.css": {
      "development": "./src/tailwind.css",
      "default": "./dist/tailwind.css"
    },
    "./tailwind-theme.css": {
      "development": "./src/tailwind-theme.css",
      "default": "./dist/tailwind-theme.css"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "gen:tokens": "node scripts/gen-tokens-css.mjs",
    "gen:tokens:check": "node scripts/gen-tokens-css.mjs --check",
    "check:component-tokens": "node scripts/check-component-tokens.mjs",
    "gen:component-tokens-doc": "node scripts/gen-component-tokens-doc.mjs",
    "build": "node scripts/gen-tokens-css.mjs --check && node scripts/check-component-tokens.mjs && node scripts/gen-component-tokens-doc.mjs --check && vite build && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@manti-ui/tokens": "workspace:*"
  }
}
