{
  "name": "@manti-ui/tokens",
  "version": "0.3.0",
  "description": "Framework-agnostic design token contract for Manti UI.",
  "license": "MIT",
  "homepage": "https://manti.design",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/manti-ui/ui.git",
    "directory": "packages/tokens"
  },
  "keywords": [
    "design-system",
    "design-tokens",
    "ui"
  ],
  "type": "module",
